RAG_APP_NAME=Enterprise RAG Service
RAG_APP_VERSION=1.0.0
RAG_ENVIRONMENT=production
RAG_API_PREFIX=/api/v1
RAG_RETRIEVAL_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_MIN_SCORE_THRESHOLD=0.15
RAG_EMBEDDING_PROVIDER=openai-compatible
RAG_EMBEDDING_DIMENSIONS=1536
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_API_KEY=your_embedding_api_key
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_TIMEOUT=30
RAG_LLM_PROVIDER=openai-compatible
RAG_LLM_MODEL=gpt-4o-mini
RAG_LLM_API_KEY=your_llm_api_key
RAG_LLM_BASE_URL=
RAG_LLM_TIMEOUT=60
RAG_LLM_TEMPERATURE=0.2
RAG_LEXICAL_WEIGHT=0.45
RAG_SEMANTIC_WEIGHT=0.55
RAG_VECTOR_CANDIDATE_LIMIT=100
RAG_OPENSEARCH_ENABLED=true
RAG_OPENSEARCH_URL=http://opensearch:9200
RAG_OPENSEARCH_INDEX=rag_chunks
RAG_OPENSEARCH_TIMEOUT=5
RAG_OPENSEARCH_CANDIDATE_LIMIT=100
RAG_OPENSEARCH_WEIGHT=0.2
RAG_DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/ragdb
RAG_DATABASE_ECHO=false
RAG_DATABASE_POOL_SIZE=20
RAG_DATABASE_MAX_OVERFLOW=30
RAG_DATABASE_CONNECT_TIMEOUT=5
RAG_CORS_ALLOW_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080"]
RAG_CORS_ALLOW_CREDENTIALS=true
RAG_STORAGE_LOCAL_ROOT=/data/uploads
RAG_AUTH_SECRET_KEY=replace_with_a_real_secret
RAG_AUTH_TOKEN_TTL_MINUTES=480
