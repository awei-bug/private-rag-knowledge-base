RAG_APP_NAME=Local RAG Knowledge Base
RAG_APP_VERSION=0.1.0
RAG_ENVIRONMENT=development
RAG_API_PREFIX=/api/v1
RAG_RETRIEVAL_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_MIN_SCORE_THRESHOLD=0.15
RAG_EMBEDDING_PROVIDER=hashing
RAG_EMBEDDING_DIMENSIONS=128
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_TIMEOUT=30
RAG_LLM_PROVIDER=template
RAG_LLM_MODEL=gpt-4o-mini
RAG_LLM_API_KEY=
RAG_LLM_BASE_URL=
RAG_LLM_TIMEOUT=60
RAG_LLM_TEMPERATURE=0.2
RAG_LEXICAL_WEIGHT=0.45
RAG_SEMANTIC_WEIGHT=0.55
RAG_VECTOR_CANDIDATE_LIMIT=100
RAG_OPENSEARCH_ENABLED=false
RAG_OPENSEARCH_URL=http://127.0.0.1:9200
RAG_OPENSEARCH_INDEX=rag_chunks
RAG_OPENSEARCH_TIMEOUT=5
RAG_OPENSEARCH_CANDIDATE_LIMIT=100
RAG_OPENSEARCH_WEIGHT=0.2
RAG_DATABASE_URL=postgresql+psycopg://rag:rag@127.0.0.1:5432/ragdb
RAG_DATABASE_ECHO=false
RAG_DATABASE_POOL_SIZE=10
RAG_DATABASE_MAX_OVERFLOW=20
RAG_DATABASE_CONNECT_TIMEOUT=5
RAG_CORS_ALLOW_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173","http://127.0.0.1:5174","http://localhost:5174"]
RAG_CORS_ALLOW_CREDENTIALS=true
RAG_STORAGE_LOCAL_ROOT=./data/uploads
RAG_BACKUP_LOCAL_ROOT=./data/backups
RAG_LOCAL_MODE_ENABLED=true
